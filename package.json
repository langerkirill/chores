{
  "name": "chores",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --check docs/app.js && node --check worker/src/index.js",
    "serve": "npx http-server docs -p 4173 -a 127.0.0.1",
    "worker:dev": "npx wrangler dev",
    "worker:deploy": "npx wrangler deploy",
    "d1:create": "npx wrangler d1 create chores",
    "d1:migrate": "npx wrangler d1 migrations apply chores --remote"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "wrangler": "^4.14.4"
  }
}
